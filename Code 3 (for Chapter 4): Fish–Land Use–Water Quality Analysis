library(sf)
library(dplyr)
library(tidyr)
library(glmmTMB)
library(tibble)
base_dir  <- "E:/.../DATA"
years     <- c(2001, 2010, 2020)
buffers   <- c("300M", "1KM")
responses <- c("FishCo", "SpeCo")
site_id   <- "Station_Nu"
lu_all <- c("Residential","Commercial","Industrial","Institutional",
            "TCU","Agricultural","OpenSpace","VacUC","WaterOther")
ref_class <- "WaterOther"
yr_suffix <- function(y) {
  if (y == 2001) return("01")
  if (y == 2010) return("10")
  if (y == 2020) return("20")
  stop("Year must be one of 2001, 2010, 2020")
}
build_path <- function(base_dir, buffer, year) {
  file.path(base_dir, paste0(buffer, "_", year), paste0(buffer, "_", year, ".shp"))
}
partial_pseudo_r2 <- function(m_reduced, m_full) {
  ll_red  <- as.numeric(logLik(m_reduced))  # WQ-only
  ll_full <- as.numeric(logLik(m_full))     # WQ + LU
  r2 <- 1 - (ll_full / ll_red)
  list(r2 = r2, ll_reduced = ll_red, ll_full = ll_full)
}
is_bad_fit <- function(mod) {
  bad_ll <- anyNA(c(as.numeric(logLik(mod)), AIC(mod)))
  bad_hess <- isTRUE(tryCatch(mod$sdr$pdHess == FALSE, error = function(e) FALSE))
  bad_ll || bad_hess
}
safe_lrt_p <- function(m1, m2) {
  out <- tryCatch({
    lrt <- anova(m1, m2)
    p <- lrt$`Pr(>Chisq)`[2]
    list(p = p, msg = "")
  }, error = function(e) {
    list(p = NA_real_, msg = paste("anova failed:", conditionMessage(e)))
  })
  out
}
reclass_landuse <- function(dat, year) {
  dat %>%
    mutate(
      Land_Use = case_when(
        year == 2001 & LANDUSE %in% c(1110, 1111, 1120, 1112, 1130, 1140, 1151) ~ "Residential",
        year == 2001 & LANDUSE %in% c(1250, 1232, 1223, 1222, 1221, 1211, 1212, 1214, 1215, 1216, 1220, 1240, 1250) ~ "Commercial",
        year == 2001 & LANDUSE %in% c(1310, 1320, 1321, 1322, 1330, 1340, 1350, 1360, 1370, 1380) ~ "Institutional",
        year == 2001 & LANDUSE %in% c(1410, 1420, 1430, 1431, 1432, 1433, 1440, 1444, 1450) ~ "Industrial",
        year == 2001 & LANDUSE %in% c(1231, 1511, 1512, 1520, 1530, 1540, 1550, 1560,
                                      1561, 1562, 1563, 1564, 1565, 1570) ~ "TCU",
        year == 2001 & LANDUSE %in% c(2000, 2100, 2200, 2300) ~ "Agricultural",
        year == 2001 & LANDUSE %in% c(3100, 3200, 3300, 3400, 3500, 3600) ~ "OpenSpace",
        year == 2001 & LANDUSE %in% c(4110, 4120, 4130, 4140, 4210, 4220, 4230, 4240, 4300) ~ "VacUC",
        year == 2001 & LANDUSE %in% c(5000, 5100, 5200, 6000, 9999) ~ "WaterOther",
        year == 2010 & LANDUSE %in% c(1110, 1111, 1120, 1112, 1130, 1140, 1151) ~ "Residential",
        year == 2010 & LANDUSE %in% c(1211, 1212, 1214, 1215, 1216, 1220, 1221, 1222, 1223, 1232, 1240, 1250) ~ "Commercial",
        year == 2010 & LANDUSE %in% c(1310, 1320, 1321, 1322, 1330, 1340, 1350, 1360, 1370, 1380) ~ "Institutional",
        year == 2010 & LANDUSE %in% c(1410, 1420, 1430, 1431, 1432, 1433, 1440, 1444, 1450) ~ "Industrial",
        year == 2010 & LANDUSE %in% c(6300, 1511, 1512, 1520, 1530, 1540, 1550, 1560,
                                      1561, 1562, 1563, 1564, 1565, 1570) ~ "TCU",
        year == 2010 & LANDUSE %in% c(2000, 2100, 2200, 2300) ~ "Agricultural",
        year == 2010 & LANDUSE %in% c(3100, 3200, 3300, 3400, 3500, 3600) ~ "OpenSpace",
        year == 2010 & LANDUSE %in% c(4110, 4120, 4130, 4140, 4210, 4220, 4230, 4240, 4300) ~ "VacUC",
        year == 2010 & LANDUSE %in% c(5000, 5100, 5200, 6000, 6100, 6200, 6400, 9999) ~ "WaterOther",
        year == 2020 & LANDUSE %in% c(1111, 1112, 1130, 1140, 1151) ~ "Residential",
        year == 2020 & LANDUSE %in% c(1211, 1212, 1214, 1215, 1216, 1220, 1240, 1250) ~ "Commercial",
        year == 2020 & LANDUSE %in% c(1310, 1321, 1322, 1330, 1340, 1350, 1360, 1370, 1380) ~ "Institutional",
        year == 2020 & LANDUSE %in% c(1410, 1420, 1431, 1432, 1433, 1450) ~ "Industrial",
        year == 2020 & LANDUSE %in% c(1511, 1512, 1520, 1530, 1540, 1550, 1561, 1562, 1563, 1564, 1565, 1570) ~ "TCU",
        year == 2020 & LANDUSE %in% c(2000) ~ "Agricultural",
        year == 2020 & LANDUSE %in% c(3100, 3200, 3300, 3400, 3500) ~ "OpenSpace",
        year == 2020 & LANDUSE %in% c(4110, 4120, 4130, 4140, 4210, 4220, 4230, 4240) ~ "VacUC",
        year == 2020 & LANDUSE %in% c(5000, 6000, 9999) ~ "WaterOther",
        TRUE ~ NA_character_
      )
