  out <- ex |>
    filter(!is.na(.data[[valcol]])) |>
    mutate(LU = .data[[valcol]]) |>
    group_by(PID, .data[[site_id]], LU) |>
    summarise(n = n(), .groups = "drop") |>
    group_by(PID, .data[[site_id]]) |>
    mutate(pct = 100 * n / sum(n)) |>
    ungroup() |>
    mutate(lu_year = as.integer(lu_year))
