clip_to_ws <- function(r, ws) {
  ws2 <- terra::project(ws, terra::crs(r))
  terra::mask(terra::crop(r, ws2), ws2)
}
align_to_template <- function(r, template, method="near") {
  r2 <- terra::project(r, template, method = method)
  terra::resample(r2, template, method = method)
}
get_landuse_field <- function(v) {
  prefs <- c("LANDUSE","LandUse","landuse","LU","LU_CODE","LUCODE","CLASS","Class","CATEGORY","Category")
  cn <- names(v)
  hit <- prefs[prefs %in% cn]
  if (length(hit) > 0) return(hit[1])
  if (length(cn) == 0) stop("No attributes found in land-use shapefile.")
  cn[1]
}
get_attr_vec <- function(v, field) {
  x <- v[[field]]
  if (is.list(x)) x <- unlist(x, use.names = FALSE)
  if (is.null(x) || length(x) == 0) {
    x <- terra::values(v)[[field]]
    if (is.list(x)) x <- unlist(x, use.names = FALSE)
  }
  x
}
safe_write_unique <- function(r, base_name, datatype=NULL) {
  f <- file.path(out_dir, paste0(base_name, "_", RUN_ID, ".tif"))
  if (is.null(datatype)) {
    terra::writeRaster(r, f, overwrite = TRUE)
  } else {
    terra::writeRaster(r, f, overwrite = TRUE, datatype = datatype)
  }
  terra::rast(f)
}
