fit_one_wq <- function(data, y_col, lu_cols, out_dir) {
  dat <- data %>%
    select(station, year, year_c, all_of(y_col), all_of(lu_cols)) %>%
    filter(!is.na(.data[[y_col]])) %>%
    drop_na(all_of(lu_cols))
  y <- dat[[y_col]]
  if (any(y < 0, na.rm = TRUE)) {
    shift <- abs(min(y, na.rm = TRUE))
    dat <- dat %>% mutate(y_use = log1p(.data[[y_col]] + shift))
  } else {
    dat <- dat %>% mutate(y_use = log1p(.data[[y_col]]))
  }
  fml <- as.formula(
    paste("y_use ~", paste(c(lu_cols, "year_c"), collapse = " + "), "+ (1|station)")
  )
  mod <- lmer(fml, data = dat, REML = FALSE)
  coefs <- broom.mixed::tidy(mod, effects = "fixed", conf.int = TRUE) %>%
    mutate(
      outcome = y_col,
      n_obs = nrow(dat),
      n_stations = n_distinct(dat$station)
    )
  diag <- tibble(
    outcome = y_col,
    n_obs = nrow(dat),
    n_stations = n_distinct(dat$station),
    AIC = AIC(mod),
    BIC = BIC(mod),
    R2_marginal = tryCatch(performance::r2(mod)$R2_marginal, error = function(e) NA_real_),
    R2_conditional = tryCatch(performance::r2(mod)$R2_conditional, error = function(e) NA_real_),
    singular = lme4::isSingular(mod, tol = 1e-4)
  )
  saveRDS(mod, file.path(out_dir, paste0("model_", y_col, ".rds")))
  write_csv(coefs, file.path(out_dir, paste0("coef_", y_col, ".csv")))
  write_csv(diag,  file.path(out_dir, paste0("diag_", y_col, ".csv")))
 
  list(model = mod, coefs = coefs, diag = diag)
}
