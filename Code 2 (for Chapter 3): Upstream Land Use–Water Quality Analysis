predict_ranger_blocks <- function(X_disk, model, out_file,
                                 gap01_disk = NULL,
                                 block_nrows = 256,
                                 lc_levels = NULL,
                                 num_threads = 1) {
  terra::readStart(X_disk)
  if (!is.null(gap01_disk)) terra::readStart(gap01_disk)
  nr_total <- terra::nrow(X_disk)
  nc_total <- terra::ncol(X_disk)
  if (length(nr_total) != 1 || is.na(nr_total)) stop("Bad nrow(X_disk).")
  if (length(nc_total) != 1 || is.na(nc_total)) stop("Bad ncol(X_disk).")
  starts <- seq.int(1L, nr_total, by = as.integer(block_nrows))
  n_blocks <- length(starts)
  pred <- terra::rast(X_disk[[1]])
  terra::values(pred) <- NA_integer_
  names(pred) <- "pred"
  terra::writeStart(pred, filename = out_file, overwrite = TRUE, datatype = "INT2S")
  b <- 0L
  for (r0 in starts) {
    b <- b + 1L
    nr <- min(block_nrows, nr_total - r0 + 1L)
    Xv  <- terra::readValues(X_disk, row = r0, nrows = nr, mat = TRUE)
    out <- rep(NA_integer_, nrow(Xv))  # nr * ncol
    if (is.null(gap01_disk)) {
      ok <- which(complete.cases(Xv))
    } else {
      gv <- terra::readValues(gap01_disk, row = r0, nrows = nr, mat = FALSE)
      need <- which(gv == 1)
      ok <- need[complete.cases(Xv[need, , drop = FALSE])]
    }
    if (length(ok) > 0) {
      d <- data.frame(
        landcover     = Xv[ok, 1],
        elevation_m   = Xv[ok, 2],
        slope_deg     = Xv[ok, 3],
        flowacc_cells = Xv[ok, 4],
        twi           = Xv[ok, 5]
      )
      d$landcover <- if (!is.null(lc_levels)) factor(d$landcover, levels = lc_levels) else factor(d$landcover)
      p <- predict(model, data = d, num.threads = num_threads)$predictions
      p_int <- suppressWarnings(as.integer(as.character(p)))
      if (all(is.na(p_int))) p_int <- as.integer(p)
      out[ok] <- p_int
    }
    # ✅ KEY FIX: start is ROW index in your terra build (not a cell index)
    terra::writeValues(pred, out, r0, nr)

    if (b %% 5L == 0L) cat("  block", b, "of", n_blocks, "\n")
  }
  pred <- terra::writeStop(pred)
  terra::readStop(X_disk)
  if (!is.null(gap01_disk)) terra::readStop(gap01_disk)
  terra::rast(out_file)
}
ws <- terra::vect(ws_path)
terrain_full <- terra::rast(terrain_stack_file)
names(terrain_full) <- c("elevation_m","slope_deg","flowacc_cells","twi")
terrain0 <- clip_to_ws(terrain_full, ws)
terrain  <- safe_write_unique(terrain0, "TerrainHydro_stack_utm16_CLIPPED", datatype = "FLT4S")
rm(terrain0, terrain_full); gc()
cat("\nTemplate:\n"); print(terrain)
for (lu_year in names(pair_map)) {
  lc_year <- pair_map[[lu_year]]
  yr_int  <- as.integer(lu_year)
  cat("\n=================================================\n")
  cat("LAND USE YEAR:", lu_year, " | LAND COVER YEAR:", lc_year, "\n")
  cat("RUN_ID:", RUN_ID, "\n")
  cat("=================================================\n")
  lc0 <- terra::rast(landcover_files[[lc_year]])
  lc0 <- align_to_template(lc0, terrain[[1]], method = "near")
  lc0 <- terra::mask(lc0, terrain[[1]])
  names(lc0) <- "landcover"
  lc  <- safe_write_unique(lc0, paste0("LandCover_", lc_year, "_aligned"), datatype = "INT2U")
  rm(lc0); gc()
  lu_vec <- terra::vect(landuse_vec_files[[lu_year]])
  lu_vec <- terra::project(lu_vec, terra::crs(terrain))
  lu_code_field <- get_landuse_field(lu_vec)
  cat("Using land-use code field:", lu_code_field, "\n")
  lu_codes <- suppressWarnings(as.integer(as.character(get_attr_vec(lu_vec, lu_code_field))))
  lu_grp   <- recode_landuse(yr_int, lu_codes)
  lu_id    <- as.integer(factor(lu_grp, levels = LU_LEVELS))
  lu_vec$LU_ID <- lu_id
  lu_r0 <- terra::rasterize(lu_vec, terrain[[1]], field = "LU_ID", touches = TRUE)
  lu_r0 <- terra::mask(lu_r0, terrain[[1]])
  names(lu_r0) <- "landuse_id"
  labeled <- terra::global(!is.na(lu_r0), "sum", na.rm = TRUE)[1,1]
  cat("Labeled cells:", labeled, "out of", terra::ncell(lu_r0), "\n")
  lu_r <- safe_write_unique(lu_r0, paste0("LandUse_labels_id_", lu_year, "_template"), datatype = "INT2S")
  rm(lu_r0, lu_vec); gc()
  X0 <- c(lc, terrain)
  names(X0) <- c("landcover","elevation_m","slope_deg","flowacc_cells","twi")
  X  <- safe_write_unique(X0, paste0("Predictors_X_", lu_year), datatype = "FLT4S")
  rm(X0); gc()
  idx_all <- which(!is.na(terra::values(lu_r, mat = FALSE)))
  if (length(idx_all) == 0) stop("No labeled pixels for ", lu_year)
  s_idx <- sample(idx_all, min(max_train, length(idx_all)))
  pts   <- terra::vect(terra::xyFromCell(terrain[[1]], s_idx), crs = terra::crs(terrain))
  lc_vals  <- terra::extract(lc, pts)[, -1, drop = FALSE]
  ter_vals <- terra::extract(terrain, pts)[, -1, drop = FALSE]
  y_vals   <- terra::values(lu_r)[s_idx]
  names(lc_vals)  <- "landcover"
  names(ter_vals) <- c("elevation_m","slope_deg","flowacc_cells","twi")
  df <- data.frame(
    landcover  = factor(lc_vals$landcover),
    ter_vals,
    landuse_id = factor(y_vals)
  )
  df <- na.omit(df)
  cat("Training samples used:", nrow(df), " | classes:", length(unique(df$landuse_id)), "\n")
  if (nrow(df) < 1000) stop("Too few training rows for ", lu_year)
  lc_levels <- levels(df$landcover)
  model <- ranger(
    landuse_id ~ .,
    data = df,
    num.trees = n_trees,
    importance = "impurity",
    probability = FALSE,
    num.threads = num_threads
  )
  gap01 <- safe_write_unique(
    terra::ifel(is.na(lu_r), 1, 0),
    paste0("GAP01_", lu_year),
    datatype = "INT1U"
  )
  pred_gap_file <- file.path(out_dir, paste0("LandUse_pred_id_", lu_year, "_GAPS_", RUN_ID, ".tif"))
  cat("Predicting gaps (manual blocks) ...\n")
  pred_gaps <- predict_ranger_blocks(
    X_disk      = X,
    model       = model,
    out_file    = pred_gap_file,
    gap01_disk  = gap01,
    block_nrows = block_nrows,
    lc_levels   = lc_levels,
    num_threads = num_threads
  )
  pred_full <- terra::cover(lu_r, pred_gaps)
  names(pred_full) <- paste0("LU_pred_id_", lu_year)
  pred_full <- safe_write_unique(
    pred_full,
    paste0("LandUse_pred_id_", lu_year, "_WATERSHED"),
    datatype = "INT2S"
  )
  cat("Saved gaps-only :", pred_gap_file, "\n")
  cat("Saved full pred :", terra::sources(pred_full), "\n")
  cat("Saved labels    :", terra::sources(lu_r), "\n")

  rm(df, model, pred_gaps, pred_full, gap01, X, lc, lu_r, pts, lc_vals, ter_vals, y_vals)
  gc()
}
