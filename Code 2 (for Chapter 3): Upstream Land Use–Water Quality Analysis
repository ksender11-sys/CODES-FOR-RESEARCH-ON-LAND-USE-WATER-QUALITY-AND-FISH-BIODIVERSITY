  snap_dist  = POUR_SNAP_DIST_M
)
if (!file.exists(pour_snapped)) stop("Snapped pour points not created.")
cat("Delineating watersheds...\n")
wbt_watershed(
  d8_pntr  = d8_ptr,
  pour_pts = pour_snapped,
  output   = wshed_ras
)
if (!file.exists(wshed_ras)) stop("Watershed raster not created.")
cat("Converting watershed raster to polygons...\n")
wr <- rast(wshed_ras)
ws_poly <- as.polygons(wr, dissolve = TRUE, values = TRUE, na.rm = TRUE)
watersheds_raw <- st_as_sf(ws_poly) |>
  st_transform(target_crs) |>
  st_make_valid()
poly_idx <- st_geometry_type(watersheds_raw) %in% c("POLYGON", "MULTIPOLYGON")
watersheds_raw <- watersheds_raw[poly_idx, , drop = FALSE]
watersheds_raw <- watersheds_raw[!st_is_empty(watersheds_raw), , drop = FALSE]
watersheds_raw <- st_cast(watersheds_raw, "MULTIPOLYGON", warn = FALSE)
pour_pts_snapped <- st_read(pour_snapped, quiet = TRUE) |>
  st_transform(target_crs) |>
  st_make_valid()
if (!("PID" %in% names(pour_pts_snapped))) {
  df0 <- st_drop_geometry(pour_pts_snapped)
  num_cols <- names(df0)[sapply(df0, function(x) is.numeric(x) || is.integer(x))]
  if (length(num_cols) == 0) stop("Could not recover PID from snapped pour points.")
  pour_pts_snapped <- pour_pts_snapped |>
    mutate(PID = as.integer(.data[[num_cols[1]]]))
}
pour_small <- pour_pts_snapped |>
  dplyr::select(any_of(c("PID", site_id)))
watersheds <- st_join(watersheds_raw, pour_small, join = st_intersects, left = TRUE)
miss <- which(is.na(watersheds$PID))
if (length(miss) > 0) {
  idx_near <- st_nearest_feature(watersheds[miss, ], pour_small)
  watersheds$PID[miss] <- pour_small$PID[idx_near]
  if (site_id %in% names(pour_small)) {
    watersheds[[site_id]][miss] <- pour_small[[site_id]][idx_near]
  }
}
watersheds <- watersheds |>
  mutate(
    area_m2  = as.numeric(st_area(geometry)),
    area_km2 = area_m2 / 1e6
  ) |>
  arrange(PID)
watersheds_shp  <- file.path(out_dir, "watersheds_with_pid.shp")
watersheds_gpkg <- file.path(out_dir, "watersheds_with_pid.gpkg")
unlink(list.files(out_dir, pattern = "^watersheds_with_pid\\.", full.names = TRUE))
st_write(watersheds, watersheds_shp, quiet = TRUE)
st_write(watersheds, watersheds_gpkg, layer = "watersheds_with_pid", delete_dsn = TRUE, quiet = TRUE)
cat("\nDONE.\n")
cat("Outputs:\n")
cat("- ", watersheds_shp, "\n", sep = "")
cat("- ", watersheds_gpkg, "\n", sep = "")
cat("- ", pour_snapped, "\n", sep = "")
cat("- ", wshed_ras, "\n", sep = "")
cat("\nWatershed area summary (km²):\n")
print(summary(watersheds$area_km2))
