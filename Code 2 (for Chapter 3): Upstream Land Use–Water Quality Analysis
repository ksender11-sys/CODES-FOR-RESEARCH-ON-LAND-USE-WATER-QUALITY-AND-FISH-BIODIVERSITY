    mutate(LU_label = factor(LU, levels = 1:9, labels = LU_LEVELS)) |>
    select(PID, all_of(site_id), lu_year, LU_label, pct) |>
    pivot_wider(names_from = LU_label, values_from = pct, values_fill = 0)
}
