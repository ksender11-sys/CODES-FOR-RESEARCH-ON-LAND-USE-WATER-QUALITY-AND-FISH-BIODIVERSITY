nearest_point_on_line_robust <- function(points_sf, lines_sf) {
  idx <- sf::st_nearest_feature(points_sf, lines_sf)
  snapped_sfg <- vector("list", nrow(points_sf))
  snap_dist_m <- numeric(nrow(points_sf))
  for (i in seq_len(nrow(points_sf))) {
    li  <- lines_sf[idx[i], ]
    seg <- sf::st_nearest_points(points_sf[i, ], li)
    pts <- sf::st_cast(seg, "POINT")
    npts <- length(pts)
    if (npts >= 2)      p_on_line <- pts[[npts]]
    else if (npts == 1) p_on_line <- pts[[1]]
    else                p_on_line <- sf::st_geometry(points_sf[i, ])[[1]]
    snapped_sfg[[i]] <- p_on_line
    p_sf <- sf::st_as_sf(sf::st_sfc(p_on_line, crs = sf::st_crs(points_sf)))
    snap_dist_m[i] <- as.numeric(sf::st_distance(points_sf[i, ], p_sf, by_element = TRUE))
  }
  out <- points_sf
  st_geometry(out) <- st_sfc(snapped_sfg, crs = st_crs(points_sf))
  out$SNAP_DIST_M <- snap_dist_m
  out
}
